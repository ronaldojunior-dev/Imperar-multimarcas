generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  VENDEDOR
}

enum VehicleStatus {
  ATIVO
  RESERVADO
  VENDIDO
  ARQUIVADO
}

enum LeadStatus {
  NOVO
  CONTATO
  NEGOCIACAO
  FECHADO
  PERDIDO
}

enum LeadType {
  CONTATO
  FINANCIAMENTO
  VENDA_VEICULO
  WHATSAPP
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(VENDEDOR)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
}

model Vehicle {
  id           String        @id @default(cuid())
  slug         String        @unique
  brand        String
  model        String
  version      String
  year         Int
  mileage      Int
  fuel         String
  transmission String
  color        String
  doors        Int
  plateFinal   String
  price        Decimal       @db.Decimal(12, 2)
  featured     Boolean       @default(false)
  status       VehicleStatus @default(ATIVO)
  description  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  images      VehicleImage[]
  leads       Lead[]
  simulations FinancingSimulation[]
  views       VehicleView[]

  @@index([brand, model])
  @@index([featured, status])
  @@index([price])
}

model VehicleImage {
  id        String  @id @default(cuid())
  vehicleId String
  imageUrl  String
  order     Int     @default(0)

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, order])
}

model Lead {
  id        String     @id @default(cuid())
  vehicleId String?
  type      LeadType   @default(CONTATO)
  name      String
  phone     String
  email     String?
  message   String
  status    LeadStatus @default(NOVO)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  vehicle Vehicle?      @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  notes   LeadNote[]
  history LeadHistory[]

  @@index([status, createdAt])
  @@index([vehicleId])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  note      String
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadHistory {
  id        String   @id @default(cuid())
  leadId    String
  from      String?
  to        String
  note      String?
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Testimonial {
  id     String  @id @default(cuid())
  name   String
  photo  String
  text   String
  active Boolean @default(true)
}

model Banner {
  id        String    @id @default(cuid())
  title     String
  image     String
  link      String?
  active    Boolean   @default(true)
  startDate DateTime?
  endDate   DateTime?
}

model Settings {
  id              String  @id @default(cuid())
  companyName     String
  logo            String?
  phone           String
  whatsapp        String
  email           String
  address         String
  facebook        String?
  instagram       String?
  youtube         String?
  seoTitle        String?
  seoDescription  String?
  googleAnalytics String?
  metaPixel       String?
}

model FinancingSimulation {
  id          String   @id @default(cuid())
  vehicleId   String?
  name        String?
  phone       String?
  vehiclePrice Decimal @db.Decimal(12, 2)
  downPayment Decimal @db.Decimal(12, 2)
  installments Int
  monthlyRate Decimal @db.Decimal(6, 4)
  installmentValue Decimal @db.Decimal(12, 2)
  totalValue  Decimal @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
}

model VehicleView {
  id        String   @id @default(cuid())
  vehicleId String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([createdAt])
}
